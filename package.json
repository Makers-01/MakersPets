    "provider:test": "node --env-file=.env scripts/test-provider.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "electron": "^35.7.5",
    "prisma": "^6.8.2",
    "typescript": "^5.8.3"
  }
}
